// ToneMappingMode - Tone mapping algorithm constants
// Use with PostProcess::setToneMappingMode(ToneMappingMode::ACES)

public class ToneMappingMode {
    public static final int ACES = 0;
    public static final int REINHARD = 1;
    public static final int UNCHARTED2 = 2;
    public static final int LINEAR = 3;
    public static final int GRAN_TURISMO = 4;
    public static final int AGX = 5;
    public static final int KHRONOS_PBR_NEUTRAL = 6;
}
